# ==============================================
# Docker ignore file for Next.js project
# Exclude files from Docker build context
# ==============================================

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Next.js build output
.next/
out/
build/
dist/

# Environment files (use build args or runtime env instead)
.env
.env.local
.env*.local
.env.development
.env.production

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore
.gitattributes

# Testing
coverage/
.nyc_output/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
test/
tests/

# Documentation
README.md
CHANGELOG.md
LICENSE
*.md

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Docker
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# Misc
.prettierrc
.prettierignore
.editorconfig
.eslintcache
*.log
logs/
temp/
tmp/


